# Copy to .env for local dev. Railway: set these as service variables.
ENV=dev

# Local default: postgres via `docker compose up -d db` (port 55442).
# Production: Supavisor transaction pooler URL, port 6543 — NOT the direct connection.
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# SUPABASE_URL=https://<project-ref>.supabase.co
# CORS_ORIGINS=[]

# SCHEDULER_ENABLED=true
