# Copy to dart_defines.env (gitignored) and fill in real values.
# Every --dart-define the app reads via String.fromEnvironment must be
# listed here — a value that's silently missing falls back to its
# in-code default, which for API_BASE_URL/SUPABASE_URL/SUPABASE_PUBLISHABLE_KEY
# means the app quietly runs unconfigured (see CLAUDE.md's "Lessons learned").
API_BASE_URL=https://api.kitabi.in
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
